# .env.example
#
# Copy to .env and fill in values.
# This file is loaded by both api and frontend containers, and local scripts.

# ── Database (Turso/libsql) ──────────────────────────────────────────────
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# ── Machine Learning (Databricks/MLflow) ──────────────────────────────────
DATABRICKS_HOST=https://dbc-your-workspace.cloud.databricks.com/
DATABRICKS_TOKEN=your-dapi-token
# DATABRICKS_USER_EMAIL=your.email@company.com  # Optional: routes experiment to /Users/email instead of /Shared/
# MLFLOW_REGISTRY_URI=databricks-uc             # Optional: defaults to databricks-uc

# ── Data Collection (Steam) ──────────────────────────────────────────────
STEAM_API_KEY=your-steam-api-key

# ── LLM (Groq) ────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key

# ── Langfuse (optional — tracing disabled if unset) ──────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Zilliz (optional — similarity search disabled if unset) ─────────────
ZILLIZ_URI=
ZILLIZ_TOKEN=

# ── ITAD (optional — price tracking) ─────────────────────────────────────
ITAD_API_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────
# Overridden to http://api:8000 inside docker-compose; only needed for
# running frontend outside docker against a local API.
API_BASE_URL=http://localhost:8000
